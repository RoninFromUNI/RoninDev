<!--
  plugin.xml — the integration manifest for therapeutic dev.
  
  every component in the plugin is registered here. intellij reads this at
  startup to know which extension points to wire up, which services to make
  available, and which listeners to subscribe to message bus topics.
  
  if something isn't registered here, it doesn't exist as far as the ide is concerned.
-->
<idea-plugin>
    <id>com.ronin.therapeuticdev</id>
    <n>Therapeutic Dev</n>
    <version>0.1.0-alpha</version>
    <vendor email="ronin@example.com" url="https://github.com/ronin">Ronin</vendor>

    <description><![CDATA[
    <p>Detects developer flow states through real-time IDE metrics and suggests intelligent break timing.</p>

    <p><strong>Features:</strong></p>
    <ul>
        <li>Real-time flow state detection using typing patterns, errors, and context switching</li>
        <li>Intelligent break suggestions based on flow duration and state transitions</li>
        <li>Activity heatmap showing file focus distribution</li>
        <li>Configurable detection sensitivity and break intervals</li>
    </ul>

    <p><em>Part of Final Year Project research at Brunel University London.</em></p>
    ]]></description>

    <change-notes><![CDATA[
    <p><strong>0.1.0-alpha</strong></p>
    <ul>
        <li>Initial alpha release</li>
        <li>Core flow detection algorithm</li>
        <li>Basic metric collection</li>
    </ul>
    ]]></change-notes>

    <!-- ide version compatibility — sinceBuild/untilBuild must be set explicitly
         or the plugin won't install. i learned this the hard way when build 253
         rejected the plugin because untilBuild wasn't declared. -->
    <idea-version since-build="233" until-build="243.*"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ==================== STARTUP ==================== -->

        <!-- TherapeuticDevStartup kicks off SnapshotScheduler when a project opens.
             without this, no detection happens until something else triggers the service. -->
        <postStartupActivity
                implementation="com.ronin.therapeuticdev.TherapeuticDevStartup"/>

        <!-- ==================== LISTENERS (extension point based) ==================== -->

        <!-- intercepts every printable character typed in any editor.
             feeds the typing metric category (30% weight). -->
        <typedHandler
                implementation="com.ronin.therapeuticdev.listeners.TypingActivityListener"/>

        <!-- intercepts backspace/delete — separate from typedHandler because intellij
             routes deletion through the action system, not the typed handler pipeline.
             this was a platform constraint that took a while to figure out. -->
        <backspaceHandlerDelegate
                implementation="com.ronin.therapeuticdev.listeners.BackspaceHandler"/>

        <!-- ==================== UI COMPONENTS ==================== -->

        <!-- the main tool window — shows ParticipantSetupPanel first, then FlowStatePanel
             once a participant ID is entered. anchored to the right sidebar. -->
        <toolWindow
                id="Therapeutic Dev"
                anchor="right"
                icon="/icons/therapeuticDev.svg"
                factoryClass="com.ronin.therapeuticdev.ui.FlowStateToolWindowFactory"/>

        <!-- compact status bar widget at the bottom of the ide.
             shows coloured dot + score + state name. clicking opens the tool window. -->
        <statusBarWidgetFactory
                id="TherapeuticDevWidget"
                implementation="com.ronin.therapeuticdev.ui.FlowStatusBarWidgetFactory"/>

        <!-- settings panel under Settings > Tools > Therapeutic Dev.
             includes the csv export button for study data extraction. -->
        <applicationConfigurable
                parentId="tools"
                instance="com.ronin.therapeuticdev.settings.TherapeuticDevConfigurable"
                id="com.ronin.therapeuticdev.settings"
                displayName="Therapeutic Dev"/>

        <!-- ==================== APPLICATION SERVICES ==================== -->

        <!-- persistent settings — TherapeuticDevSettings has @Service but still needs
             this registration because it also implements PersistentStateComponent. -->
        <applicationService
                serviceImplementation="com.ronin.therapeuticdev.settings.TherapeuticDevSettings"/>

        <!-- sqlite persistence layer for snapshots and esm responses -->
        <applicationService
                serviceImplementation="com.ronin.therapeuticdev.storage.MetricRepository"/>

        <!-- esm probe delivery — timed self-report dialogs for the study -->
        <applicationService
                serviceImplementation="com.ronin.therapeuticdev.services.EsmProbeService"/>

        <!-- participant session — persists the participant ID across ide restarts -->
        <applicationService
                serviceImplementation="com.ronin.therapeuticdev.services.ParticipantSession"/>

    </extensions>

    <!-- ==================== PROJECT-LEVEL LISTENERS ==================== -->
    <!-- these subscribe to project message bus topics — one instance per open project -->
    <projectListeners>
        <!-- file tab switches — feeds the focus metric category (20% weight) -->
        <listener
                class="com.ronin.therapeuticdev.listeners.FileActivityListener"
                topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <!-- ==================== APPLICATION-LEVEL LISTENERS ==================== -->
    <!-- these subscribe to application message bus topics — one instance total -->
    <applicationListeners>
        <!-- ai suggestion heuristic — counts large document insertions (40+ chars)
             as probable copilot/jetbrains ai acceptances -->
        <listener
                class="com.ronin.therapeuticdev.listeners.AiSuggestionListener"
                topic="com.intellij.openapi.editor.event.EditorFactoryListener"/>

        <!-- ide focus tracking — detects alt-tab away from and back to intellij.
             feeds both focus (20%) and context (10%) scoring categories. -->
        <listener
                class="com.ronin.therapeuticdev.listeners.FocusListener"
                topic="com.intellij.openapi.application.ApplicationActivationListener"/>

        <!-- build/compilation results — feeds the builds metric category (15% weight) -->
        <listener
                class="com.ronin.therapeuticdev.listeners.BuildListener"
                topic="com.intellij.openapi.compiler.CompilationStatusListener"/>
    </applicationListeners>

</idea-plugin>
