<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <version>1.0-SNAPSHOT</version>
  <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
  <id>com.ronin.therapeuticdev.therepeutic-dev</id>
  <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
  <name>Therapeutic-Dev</name>
  <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
  <vendor email="2215624@brunel.ac.uk">Ronin</vendor>
  <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
  <description><![CDATA[<p>Detects developer flow states and suggests intelligent break timing.</p>

        <p>Features:</p>
        <ul>
            <li>Real-time flow state detection using IDE metrics</li>
            <li>Non-intrusive break suggestions</li>
            <li>Session analytics and insights</li>
        </ul>

        <p>Developed as part of a Final Year Project at Brunel University London.</p>]]></description>
  <change-notes><![CDATA[Initial version]]></change-notes>
  <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
  <!-- Minimum IDE version supported -->
  <idea-version since-build="242" until-build="242.*" />
  <!-- Required platform dependencies -->
  <depends>com.intellij.modules.platform</depends>
  <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.ronin.therapeuticdev.metrics.MetricCollector" />
    <typedHandler implementation="com.ronin.therapeuticdev.listeners.TypingActivityListener" />
    <backspaceHandlerDelegate implementation="com.ronin.therapeuticdev.listeners.BackspaceHandler" />
  </extensions>
</idea-plugin>
